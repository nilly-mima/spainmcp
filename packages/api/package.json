{
  "name": "@spainmcp/api",
  "version": "0.1.0",
  "description": "TypeScript SDK for SpainMCP — connect AI agents to MCP servers",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./mcp": {
      "types": "./dist/mcp.d.ts",
      "import": "./dist/mcp.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "dependencies": {},
  "devDependencies": {
    "typescript": "^5.7.0"
  },
  "keywords": ["mcp", "spainmcp", "ai", "agents", "sdk", "model-context-protocol"],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/nilly-mima/spainmcp"
  }
}
